{
  "name": "omp-agent-setup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Version-controlled global setup for Oh My Pi (OMP) agent tooling.",
  "scripts": {
    "bootstrap": "bun run src/cli.ts bootstrap",
    "verify": "bun run src/cli.ts verify",
    "doctor": "bun run src/cli.ts doctor",
    "update-superpowers": "bun run src/cli.ts update-superpowers",
    "update-plannotator": "bun run src/cli.ts update-plannotator",
    "ci": "bun run check:lint && bun run check:types && bun run check:dead && bun run check:audit && bun run check:test",
    "check:lint": "biome ci .",
    "check:types": "tsc --noEmit",
    "check:dead": "knip",
    "check:audit": "bun audit --prod --audit-level=moderate",
    "check:test": "bun test --coverage",
    "fix": "biome check --write ."
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/bun": "^1.3.14",
    "knip": "6.13.1",
    "typescript": "6.0.3"
  }
}
