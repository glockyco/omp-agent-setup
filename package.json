{
  "name": "omp-agent-setup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Version-controlled global setup for Oh My Pi (OMP) agent tooling.",
  "scripts": {
    "bootstrap": "bun run src/cli.ts bootstrap",
    "verify": "bun run src/cli.ts verify",
    "doctor": "bun run src/cli.ts doctor",
    "update-superpowers": "bun run src/cli.ts update-superpowers",
    "update-plannotator": "bun run src/cli.ts update-plannotator",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "ci": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
